{
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**",
      "package.json",
      "package-lock.json",
      "Functions/**",
      "admin/**",
      ".git/**",
      "DEVELOPMENT_PLAN.md",
      "BEFORE_AFTER_COMPARISON.md",
      "HEALTH_SYSTEM_QUICKREF.md",
      "HEALTH_SYSTEM_REFACTOR.md",
      "IMPLEMENTATION_PLAN_2026-06-10.md",
      "IMPLEMENTATION_SUMMARY_2026-06-20.md",
      "NOTION_TODO.md",
      "PLANTUML_DIAGRAMS_INDEX.md",
      "PROJECT_COMPLETION_CHECKLIST.md",
      "README.md",
      "SYSTEM_ARCHITECTURE_SUMMARY.md",
      "SYSTEM_OVERVIEW.puml"
    ],
    "rewrites": [
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  },
  "functions": {
    "source": "Functions",
    "runtime": "nodejs18"
  }
}
